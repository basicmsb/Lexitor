# =====================================================
# Lexitor - .gitignore
# =====================================================

# --- Secrets & local config ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.azure/

# --- Pravna baza i korisnički dokumenti (NE u git!) ---
data/
!data/.gitkeep
uploads/
output/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Poetry ---
# poetry.lock NIJE gitignored - commitamo ga
.poetry-cache/

# --- Testing ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# --- Linting / type checking ---
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Streamlit ---
.streamlit/secrets.toml

# --- Logs ---
*.log
logs/

# --- DB / cache lokalno ---
*.db
*.sqlite
*.sqlite3
dump.rdb

# --- Docker ---
.docker/

# --- IDE / editori ---
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# --- Node (za Faza 2 Next.js frontend) ---
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Misc ---
*.bak
*.tmp
*.temp
.cache/
