# =====================================================
# Lexitor - .gitignore
# =====================================================

# --- Secrets & local config ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.azure/

# --- Pravna baza i korisnički dokumenti (NE u git!) ---
data/
!data/.gitkeep
# Whitelist: samo brand lookup lista za analyzer (kurirana, ide u repo).
# Cijeli `apps/backend/data/` ostaje ignoriran (zakoni, DKOM PDF-ovi, …).
!apps/backend/data/brands.json
uploads/
output/

# --- Generated reports / batch output ---
apps/backend/reports/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Negation: the Python `lib/` ignore above was swallowing the frontend
# source directory `apps/app/src/lib/`. Whitelist it back.
!apps/app/src/lib/
!apps/app/src/lib/**
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Poetry ---
# poetry.lock NIJE gitignored - commitamo ga
.poetry-cache/

# --- Testing ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# --- Linting / type checking ---
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Logs ---
*.log
logs/

# --- DB / cache lokalno ---
*.db
*.sqlite
*.sqlite3
dump.rdb

# --- Docker ---
.docker/

# --- IDE / editori ---
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# --- Node (Next.js frontend monorepo) ---
node_modules/
.next/
out/
.turbo/
.swc/
.vercel/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js per-app local env (apps/web/.env.local, apps/app/.env.local)
.env.local
.env.development.local
.env.production.local

# --- Misc ---
*.bak
*.tmp
*.temp
.cache/
