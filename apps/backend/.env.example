# =====================================================
# Lexitor - .env.example
# =====================================================
# Kopiraj u .env i popuni stvarnim vrijednostima.
# .env je u .gitignore - NIKAD ga ne commitati.
# =====================================================

# --- Aplikacija ---
APP_ENV=development           # development | staging | production
APP_DEBUG=true
APP_LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# --- LLM / AI ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-multilingual-v3.0

# --- Azure AI Document Intelligence (premium PDF parsing, opcionalno) ---
AZURE_DOC_INTELLIGENCE_ENDPOINT=
AZURE_DOC_INTELLIGENCE_KEY=

# --- PostgreSQL ---
DATABASE_URL=postgresql://lexitor:lexitor@localhost:5432/lexitor

# --- Redis (Celery broker + cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant (vektorska baza) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Storage ---
# Lokalno: file system | Production: Azure Blob
STORAGE_BACKEND=local         # local | azure_blob
LOCAL_STORAGE_PATH=./data/uploads

AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=lexitor-documents

# --- Auth (Faza 2+) ---
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

AZURE_AD_B2C_TENANT=
AZURE_AD_B2C_CLIENT_ID=
AZURE_AD_B2C_CLIENT_SECRET=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# JSON array — pydantic-settings 2.x requires JSON for list types
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# --- Monitoring ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
SENTRY_DSN=
